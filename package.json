{
  "name": "@holdenmatt/md-parser",
  "version": "0.1.0",
  "description": "Markdown parser primitives for frontmatter, body text, sections, and code blocks.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holdenmatt/md-parser.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "pnpm format:check && pnpm lint && pnpm test && pnpm typecheck && pnpm build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "remark-parse": "^11.0.0",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@types/mdast": "^4.0.4",
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@10.33.0"
}
